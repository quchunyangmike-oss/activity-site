---
import { getCollection } from 'astro:content';
import ActivityLayout from '../../layouts/ActivityLayout.astro';

export async function getStaticPaths() {
  const activities = await getCollection('activities');
  return activities.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const {
  title, date, location, price, capacity,
  spots_remaining, spots_updated, status,
  cover_image, qr_image, qr_type, organizer_wechat,
} = entry.data;

const qrLabel = qr_type === 'alipay' ? '支付宝' : '微信支付';
---

<ActivityLayout title={title}>
  <style>
    .cover { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; display: block; }

    .header { padding: 20px 20px 0; }
    h1 { font-size: 1.4rem; font-weight: 700; line-height: 1.3; margin-bottom: 12px; }

    .price-row {
      font-size: 1.25rem;
      font-weight: 600;
      color: #E85D04;
      margin-bottom: 8px;
    }
    .price-row .spots { color: #555; font-size: 0.95rem; font-weight: 400; }
    .spots-updated { font-size: 0.78rem; color: #999; margin-bottom: 16px; }

    .banner-full, .banner-cancelled {
      margin: 0 0 16px;
      padding: 12px 20px;
      font-size: 1rem;
      font-weight: 600;
      text-align: center;
      border-radius: 6px;
    }
    .banner-full { background: #fff3cd; color: #856404; }
    .banner-cancelled { background: #f8d7da; color: #721c24; }

    .meta { font-size: 0.9rem; color: #555; padding-bottom: 16px; border-bottom: 1px solid #eee; }
    .meta p { margin-bottom: 4px; }

    .content { padding: 20px; }
    .content :global(p) { margin-bottom: 1em; }
    .content :global(img) { max-width: 100%; border-radius: 6px; margin: 8px 0; }
    .content :global(h2) { font-size: 1.1rem; margin: 1.5em 0 0.5em; }

    .qr-section {
      margin: 0 20px 32px;
      padding: 20px;
      border: 1px solid #eee;
      border-radius: 10px;
      text-align: center;
    }
    .qr-section h2 { font-size: 1rem; font-weight: 600; margin-bottom: 12px; }
    .qr-img {
      width: 220px;
      height: 220px;
      object-fit: contain;
      border-radius: 6px;
      margin-bottom: 12px;
    }
    .qr-img-error { display: none; }
    .amount-note {
      font-size: 0.95rem;
      color: #E85D04;
      font-weight: 600;
      margin-bottom: 8px;
    }
    .save-hint { font-size: 0.82rem; color: #666; margin-bottom: 4px; }
    .save-hint-alt { font-size: 0.82rem; color: #888; margin-bottom: 12px; }
    .fallback { font-size: 0.82rem; color: #999; }

    .signup-note {
      margin: 0 20px 40px;
      padding: 14px 16px;
      background: #f5f5f5;
      border-radius: 8px;
      font-size: 0.9rem;
      color: #444;
    }
  </style>

  <!-- 封面图（16:9） -->
  <img class="cover" src={cover_image} alt={title} />

  <div class="header">
    <!-- 标题 -->
    <h1>{title}</h1>

    <!-- 价格 + 剩余名额（above fold） -->
    <div class="price-row">
      ¥{price}
      {status === 'open' && (
        <span class="spots"> · 还剩 {spots_remaining} 名额</span>
      )}
    </div>
    <div class="spots-updated">名额数据 {spots_updated} 更新</div>

    <!-- 满额 / 取消 banner -->
    {status === 'full' && (
      <div class="banner-full">本期已满，关注下期</div>
    )}
    {status === 'cancelled' && (
      <div class="banner-cancelled">本期已取消</div>
    )}

    <!-- 基本信息 -->
    <div class="meta">
      <p>🗓 {date}</p>
      <p>📍 {location}</p>
      <p>👥 共 {capacity} 名额</p>
    </div>
  </div>

  <!-- 活动介绍 -->
  <div class="content">
    <Content />
  </div>

  <!-- 收款码（仅 open 状态显示） -->
  {status === 'open' && (
    <div class="qr-section">
      <h2>扫码报名 · {qrLabel}</h2>
      <img
        class="qr-img"
        src={qr_image}
        alt={`${qrLabel}收款码`}
        onerror="this.style.display='none';this.nextElementSibling.style.display='block'"
      />
      <p class="qr-img-error fallback">
        图片加载失败，请微信联系：{organizer_wechat}
      </p>
      <p class="amount-note">⚠️ 请手动输入金额：¥{price}</p>
      <p class="save-hint">长按图片保存二维码，打开{qrLabel}扫码付款</p>
      <p class="save-hint-alt">若无法长按保存，请截图后用支付宝 / 微信扫一扫识别二维码</p>
    </div>
  )}

  <!-- 报名说明 -->
  {status === 'open' && (
    <div class="signup-note">
      扫码付款后请微信私信：孩子姓名 + 年龄
    </div>
  )}
</ActivityLayout>
