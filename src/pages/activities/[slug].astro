---
import { getCollection } from 'astro:content';
import ActivityLayout from '../../layouts/ActivityLayout.astro';

export async function getStaticPaths() {
  const activities = await getCollection('activities');
  return activities.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const {
  title, date, location, price, capacity, age_range,
  spots_remaining, spots_updated,
  cover_image, qr_image, qr_type, organizer_wechat,
  organizer_qr_image, organizer_name,
} = entry.data;

const qrLabel = qr_type === 'alipay' ? '支付宝' : '微信支付';
const contactName = organizer_name ?? '晓晴老师';
const status = entry.data.status ?? 'open';
---

<ActivityLayout title={title} ogImage={cover_image}>
  <style>
    /* ── Base ── */
    * { box-sizing: border-box; }

    .cover { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; display: block; }

    /* ── Header ── */
    .header { padding: 20px 16px 0; }
    h1 { font-size: 1.25rem; font-weight: 700; line-height: 1.45; margin-bottom: 14px; }

    .price-row { font-size: 1.3rem; font-weight: 700; color: #E85D04; margin-bottom: 4px; }
    .price-row .spots { font-size: 0.9rem; font-weight: 400; color: #666; }
    .spots-updated { font-size: 0.75rem; color: #bbb; margin-bottom: 14px; }

    /* ── Status banners ── */
    .banner {
      margin: 0 0 14px;
      padding: 10px 16px;
      font-size: 0.95rem;
      font-weight: 600;
      text-align: center;
      border-radius: 6px;
    }
    .banner-full { background: #fff3cd; color: #856404; }
    .banner-cancelled { background: #f8d7da; color: #721c24; }

    /* ── Info grid ── */
    .info-grid {
      background: #fff8f4;
      border: 1px solid #fde8d8;
      border-radius: 10px;
      padding: 14px 16px;
      margin-bottom: 4px;
      font-size: 0.88rem;
      line-height: 1.9;
      color: #333;
    }

    /* ── Divider ── */
    .divider { height: 1px; background: #f0f0f0; margin: 16px 0; }

    /* ── Main content ── */
    .content { padding: 0 16px 8px; font-size: 0.93rem; line-height: 1.85; color: #222; }

    .content :global(p) { margin-bottom: 1em; }
    .content :global(h2) {
      font-size: 1rem;
      font-weight: 700;
      margin: 1.6em 0 0.5em;
      color: #111;
    }
    .content :global(ul), .content :global(ol) {
      padding-left: 1.2em;
      margin-bottom: 1em;
    }
    .content :global(li) { margin-bottom: 0.3em; }
    .content :global(img) {
      width: 100%;
      border-radius: 8px;
      margin: 10px 0;
      display: block;
      content-visibility: auto;
    }
    /* highlight box — wrap text in > blockquote for warm background */
    .content :global(blockquote) {
      margin: 1em 0;
      padding: 12px 16px;
      background: #fff8f4;
      border-left: 3px solid #E85D04;
      border-radius: 0 8px 8px 0;
      color: #444;
      font-size: 0.88rem;
    }
    .content :global(blockquote p) { margin-bottom: 0; }

    /* ── QR section ── */
    .qr-section {
      margin: 8px 16px 0;
      padding: 20px 16px;
      border: 1px solid #eee;
      border-radius: 12px;
      text-align: center;
    }
    .qr-section h2 {
      font-size: 1rem;
      font-weight: 700;
      margin-bottom: 14px;
      color: #111;
    }
    .qr-img {
      width: 260px;
      height: 260px;
      object-fit: contain;
      border-radius: 6px;
      margin-bottom: 10px;
    }
    .qr-img-error { display: none; }
    .qr-link { display: inline-block; text-decoration: none; }
    .qr-tap-hint {
      display: block;
      font-size: 0.78rem;
      color: #999;
      margin-top: 4px;
      margin-bottom: 8px;
    }
    .amount-note {
      font-size: 1rem;
      color: #E85D04;
      font-weight: 700;
      margin-bottom: 6px;
    }
    .save-hint { font-size: 0.8rem; color: #777; margin-bottom: 3px; }
    .save-hint-alt { font-size: 0.8rem; color: #aaa; }
    .fallback { font-size: 0.8rem; color: #aaa; margin-top: 6px; }

    /* ── Organizer contact section ── */
    .contact-section {
      margin: 12px 16px 32px;
      padding: 20px 16px;
      background: #f9fafb;
      border-radius: 12px;
      text-align: center;
    }
    .contact-section h2 {
      font-size: 1rem;
      font-weight: 700;
      margin-bottom: 6px;
      color: #111;
    }
    .contact-section .tip {
      font-size: 0.83rem;
      color: #555;
      margin-bottom: 14px;
      line-height: 1.6;
    }
    .contact-section .tip strong { color: #E85D04; }
    .contact-qr {
      width: 180px;
      height: 180px;
      object-fit: contain;
      border-radius: 6px;
      margin-bottom: 8px;
    }
    .contact-section .wechat-id {
      font-size: 0.8rem;
      color: #aaa;
    }

    /* ── signup note (fallback if no organizer QR) ── */
    .signup-note {
      margin: 12px 16px 32px;
      padding: 14px 16px;
      background: #f5f5f5;
      border-radius: 8px;
      font-size: 0.88rem;
      color: #444;
      line-height: 1.7;
    }
  </style>

  <!-- 封面图（优先加载） -->
  <img class="cover" src={cover_image} alt={title} fetchpriority="high" decoding="async" />

  <div class="header">
    <h1>{title}</h1>

    <!-- 价格 + 名额 -->
    <div class="price-row">
      ¥{price}
      {status === 'open' && spots_remaining !== undefined && (
        <span class="spots"> · 还剩 {spots_remaining} 名额</span>
      )}
    </div>
    {spots_updated && <div class="spots-updated">名额数据 {spots_updated} 更新</div>}

    <!-- 满额 / 取消 -->
    {status === 'full' && <div class="banner banner-full">本期已满，关注下期 👀</div>}
    {status === 'cancelled' && <div class="banner banner-cancelled">本期已取消</div>}

    <!-- 基本信息格 -->
    <div class="info-grid">
      <div>🗓 <strong>时间：</strong>{date}</div>
      <div>📍 <strong>地址：</strong>{location}</div>
      {age_range && <div>👶 <strong>年龄：</strong>{age_range}</div>}
      <div>👬 <strong>人数：</strong>限 {capacity} 组家庭</div>
      <div>💰 <strong>费用：</strong>¥{price} / 孩子，陪同家长免费</div>
    </div>
  </div>

  <div class="divider"></div>

  <!-- 活动介绍（富文本 markdown） -->
  <div class="content">
    <Content />
  </div>

  <!-- 收款码 -->
  {status === 'open' && (
    <div class="qr-section">
      <h2>扫码报名 · {qrLabel}</h2>
      <a href={qr_image} target="_blank" class="qr-link" title="点击放大扫码">
        <img
          class="qr-img"
          src={qr_image}
          alt={`${qrLabel}收款码`}
          onerror="this.style.display='none';this.parentElement.nextElementSibling.style.display='block'"
        />
        <span class="qr-tap-hint">👆 点击放大 · 长按识别二维码</span>
      </a>
      <p class="qr-img-error fallback">图片加载失败，请微信联系：{organizer_wechat}</p>
      <p class="amount-note">扫码付款 ¥{price}</p>
      <p class="save-hint-alt">点击图片放大后，长按 → 识别图中二维码</p>
    </div>
  )}

  <!-- 联系老师（付款后） -->
  {status === 'open' && organizer_qr_image ? (
    <div class="contact-section">
      <h2>缴费成功后联系{contactName} 🌹</h2>
      <p class="tip">
        长按下方二维码 → 选「识别图中二维码」添加{contactName}<br />
        添加后请发送：<strong>付款截图 + 宝贝中文名 + 英文名 + 年龄</strong>
      </p>
      <img
        class="contact-qr"
        src={organizer_qr_image}
        alt={`${contactName}微信二维码`}
        onerror="this.style.display='none'"
      />
      <p class="wechat-id">微信号：{organizer_wechat}</p>
    </div>
  ) : status === 'open' ? (
    <div class="signup-note">
      缴费成功后请微信联系 <strong>{organizer_wechat}</strong>，发送：付款截图 + 宝贝中文名 + 英文名 + 年龄
    </div>
  ) : null}
</ActivityLayout>
